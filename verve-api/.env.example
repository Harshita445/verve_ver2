DATABASE_URL=postgresql+psycopg2://verve:verve@localhost:5432/verve
JWT_SECRET=replace-with-a-long-random-string
CORS_ORIGINS=["http://localhost:3000"]

# --- OpenAI / Whisper ---
OPENAI_API_KEY=
FEEDBACK_MODEL=gpt-4o-mini

# --- Storage (local / cloudinary / s3) ---
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Audio ---
MAX_AUDIO_SIZE_MB=50
ALLOWED_AUDIO_FORMATS=["audio/webm","audio/mp4","audio/wav","audio/mpeg","audio/ogg"]

# --- Rating ---
RATING_K_FACTOR=32
RATING_EXPECTED_SCORE_MAX=100

# --- Auth ---
RESET_TOKEN_TTL_MINUTES=30

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_SIGNUP_WINDOW_SECONDS=300

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
